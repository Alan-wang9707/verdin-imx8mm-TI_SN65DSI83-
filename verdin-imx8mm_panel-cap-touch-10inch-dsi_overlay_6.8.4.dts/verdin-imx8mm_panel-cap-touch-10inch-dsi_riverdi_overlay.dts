// Verdin with connected Capacitive Touch Display 10.1" DSI.

/dts-v1/;
/plugin/;

/ {
	compatible = "toradex,verdin-imx8mm";
};

#include <dt-bindings/interrupt-controller/arm-gic.h>
#include <dt-bindings/gpio/gpio.h>
#include "display-rvt101hvdwc00b_overlay.dtsi" 

&{/} {
	backlight: backlight-verdin-dsi {
		compatible = "pwm-backlight";
		brightness-levels = <0 45 63 88 119 158 203 255>;
		default-brightness-level = <4>;
		pwms = <&pwm1 0 6666667 0>;
		status = "okay";
	};

	reg_dsi_lvds: regulator-dsi-lvds {
		compatible = "regulator-fixed";
		enable-active-high;
		regulator-boot-on;
		/*regulator-always-on;*/
		regulator-name = "DSI_1_PWR_EN";
	};
};

&pwm1 {
	status = "okay";
};

&gpu {
	status = "okay";
};

/* Verdin I2C_2_DSI */
&i2c2 {
	#address-cells = <1>;
	#size-cells = <0>;
	status = "okay";

	bridge@2c {
		compatible = "ti,sn65dsi83";
		reg = <0x2c>;
		/* IRQ not connected */
		/* Verdin GPIO_10_DSI (SODIMM 21) */
		enable-gpios = <&gpio3 3 GPIO_ACTIVE_HIGH>;
		vcc-supply = <&reg_dsi_lvds>;
		pinctrl-names = "default";
		pinctrl-0 = <&pinctrl_gpio_10_dsi>;
   
		status = "okay";

		ports {
			#address-cells = <1>;
			#size-cells = <0>;

			port@0 {
				reg = <0>;

				dsi_riv_in: endpoint { //endpoint是插头 连接到 DSI 桥接器的输入端口也就是remote-endpoint
					data-lanes = <1 2 3 4>;
					remote-endpoint = <&mipi_dsi_bridge2_out>;//remote-endpoint是插座 
				};
			};

			port@2 {
				reg = <2>;

				lvds_out_panel_riv: endpoint {
					remote-endpoint = <&panel_in_lvds_riv>;
				};
			};
		};
	};

	touch@41 {
		compatible = "ilitek,ili2132";
		reg = <0x41>;
		/* Verdin DSI_1_INT# (TOUCH_INT#, SODIMM 17) */
		interrupt-parent = <&gpio3>;
		interrupts = <15 IRQ_TYPE_EDGE_FALLING>;
		pinctrl-names = "default";
		pinctrl-0 = <&pinctrl_gpio_9_dsi>, <&pinctrl_i2s_2_bclk_touch_reset>;
		/* Verdin I2S_2_BCLK (TOUCH_RESET#, SODIMM 42) */
		reset-gpios = <&gpio3 23 GPIO_ACTIVE_LOW>;
		touchscreen-size-x = <1280>;
		touchscreen-size-y = <800>;
		wakeup-source;
		vdd-supply = <&reg_dsi_lvds>; 
		status = "okay";
	};

};

&lcdif {
	status = "okay";
};

&mipi_dsi {
	#address-cells = <1>;
	#size-cells = <0>;
	status = "okay";

	port@1 {
		mipi_dsi_bridge2_out: endpoint {
			attach-bridge;
			remote-endpoint = <&dsi_riv_in>;
		};
	};
};